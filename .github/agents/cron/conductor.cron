[[job]]
name = "sync-agents"
schedule = "*/15 * * * *"
task = "Reconcile .github/agents/ with conductor.json — retire removed agents, restore from retired/ or create new ones for additions."

[[job]]
name = "agent-health-check"
schedule = "0 * * * *"
task = "Verify that all active agents defined in conductor.json have a corresponding .agent.md file in .github/agents/. Log any discrepancies."

[[job]]
name = "session-summary"
schedule = "0 18 * * *"
task = "Generate a brief end-of-day summary of agent activity: which agents were invoked, tasks completed, and any issues encountered. Append to .github/output/sessions/."
