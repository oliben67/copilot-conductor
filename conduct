# ── Helpers ───────────────────────────────────────────────────────────────────

print_json_pretty() {
  local payload="$1"
  if command -v jq >/dev/null 2>&1 && printf '%s' "$payload" | jq -e . >/dev/null 2>&1; then
    printf '%s' "$payload" | jq --indent 2 '.'
  else
    printf '%s\n' "$payload"
  fi
}

require_key() {
  if [[ -z "${ADMIN_KEY:-}" ]]; then
    echo "Error: --key is required for admin commands." >&2
    echo "Usage: conduct admin <command> [args] --key <KEY>" >&2
    exit 1
  fi
}

api_get() {
  local endpoint="$1" response
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if response="$(curl -sf --connect-timeout 2 --max-time 5 "$url" 2>/dev/null)"; then
      printf '%s' "$response"
      return 0
    fi
  done
  return 1
}

# Like api_get but outputs "<http_status> <body>" so callers can distinguish
# 404 (not found) from connection failures (status 000).
api_get_status() {
  local endpoint="$1" out http_status body
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    out="$(curl -s --connect-timeout 2 --max-time 5 -w '\n%{http_code}' "$url" 2>/dev/null)" || true
    http_status="${out##*$'\n'}"
    body="${out%$'\n'*}"
    if [[ "$http_status" =~ ^[2-9][0-9][0-9]$ ]]; then
      printf '%s\n%s' "$http_status" "$body"
      return 0
    elif [[ "$http_status" =~ ^[0-9]+$ && "$http_status" != "000" ]]; then
      # Got an HTTP response (e.g. 404) — not a connection failure
      printf '%s\n%s' "$http_status" "$body"
      return 1
    fi
    # connection failure (status 000) — try next URL variant
  done
  printf '000\n'
  return 1
}

api_post() {
  local endpoint="$1" body="$2" response
  local url
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if response="$(curl -sf -X POST "$url" \
      -H "Content-Type: application/json" \
      -d "$body")"; then
      print_json_pretty "$response"
      return 0
    fi
  done
  return 1
}

api_patch_status_with_key() {
  local endpoint="$1" body="$2" key="$3" out http_status resp
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    out="$(curl -s --connect-timeout 2 --max-time 10 -X PATCH "$url" \
      -H "Content-Type: application/json" \
      -H "X-Admin-Key: ${key}" \
      -d "$body" \
      -w '\n%{http_code}' 2>/dev/null)" || true
    http_status="${out##*$'\n'}"
    resp="${out%$'\n'*}"
    if [[ "$http_status" =~ ^[2-9][0-9][0-9]$ ]]; then
      printf '%s\n%s' "$http_status" "$resp"
      return 0
    elif [[ "$http_status" =~ ^[0-9]+$ && "$http_status" != "000" ]]; then
      printf '%s\n%s' "$http_status" "$resp"
      return 1
    fi
  done
  printf '000\n'
  return 1
}

api_post_status_with_key() {
  local endpoint="$1" body="$2" key="$3" out http_status resp
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
