#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CON_PILOT_HOST="${CON_PILOT_HOST:-localhost}"
CON_PILOT_PORT="${CON_PILOT_PORT:-8000}"
BASE_URL="http://${CON_PILOT_HOST}:${CON_PILOT_PORT}"
CON_PILOT_API_BASE="${CON_PILOT_API_BASE:-api}"
CON_PILOT_API_VERSION="${CON_PILOT_API_VERSION:-v1}"
_api_base="${CON_PILOT_API_BASE#/}"; _api_base="${_api_base%/}"
_api_version="${CON_PILOT_API_VERSION#/}"; _api_version="${_api_version%/}"
API_PREFIX="/${_api_base}/${_api_version}"
API_URL="${BASE_URL}${API_PREFIX}"
CON_PILOT_DEV_SHOW_ME=1
unset _api_base _api_version

# Lazy-load version from service (with 2s timeout) or fall back to VERSION file
_VERSION_CACHE=""
get_version() {
  if [[ -z "$_VERSION_CACHE" ]]; then
    local http_ver
    http_ver="$(api_get "/version" \
      | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')"
    if [[ -n "$http_ver" ]]; then
      _VERSION_CACHE="$http_ver"
    else
      _VERSION_CACHE="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null \
        || cat "${CONDUCTOR_HOME:-$HOME/.conductor}/VERSION" 2>/dev/null \
        || echo 'unknown')"
    fi
  fi
  echo "$_VERSION_CACHE"
}

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
  local v; v="$(get_version)"
  cat <<EOF
conduct — Conductor v${v}  (con-pilot v${v})

Usage:
  conduct <command> [options]

Service commands:
  start                      Start the con-pilot service
  stop                       Stop the con-pilot service
  status                     Show whether con-pilot is running
  sync                       Trigger a one-shot sync cycle
  logs [-n N] [-f]           Show service logs (last 10 lines; -f to follow)
  agents [-p PROJECT] [-j]   List all agents (-j for JSON)

Project commands:
  register <name> <dir>      Register a new project
  retire <name>              Retire a project

Admin commands (require --key):
  admin replace <file> <role> [project] --key KEY   Replace agent body with file
  admin reset   <role> [project]        --key KEY   Reset agent(s) to defaults

General:
  version                    Show version information
  end-points <subcommand>    Manage API endpoint discovery and checks
  verify <item> <value>      Verify an item value (currently: key)
  help                       Show this help message
EOF
}

usage_admin() {
  cat <<EOF
conduct admin — Admin commands (require --key)

Usage:
  conduct admin <command> [args] --key <KEY>

Commands:
  replace <file> <role> [project]   Replace agent body with instructions file
  reset   <role> [project]          Reset agent(s) to template / default

Options:
  --key KEY   Admin key (required for all admin commands)

Examples:
  conduct admin replace body.md reviewer --key abc-123
  conduct admin reset developer my-app --key abc-123
EOF
}

usage_start() {
  cat <<EOF
conduct start — Start the con-pilot service

Usage:
  conduct start [options]

Description:
  Starts the con-pilot service as a background process using the AppImage.
  If the service is already running, this command does nothing.

Options:
  --help, -h    Show this help message

Environment:
  CONDUCTOR_HOME  Base directory for conductor (default: ~/.conductor)
  CON_PILOT_HOST  Service host (default: localhost)
  CON_PILOT_PORT  Service port (default: 8000)

Example:
  conduct start
EOF
}

usage_stop() {
  cat <<EOF
conduct stop — Stop the con-pilot service

Usage:
  conduct stop

Description:
  Stops any running con-pilot service processes.

Options:
  --help, -h    Show this help message

Example:
  conduct stop
EOF
}

usage_status() {
  cat <<EOF
conduct status — Show service health and version

Usage:
  conduct status

Description:
  Queries the con-pilot service for its health and version and prints
  a summary. Exits non-zero when the service is unreachable.

Options:
  --help, -h    Show this help message

Example:
  conduct status
EOF
}

usage_sync() {
  cat <<EOF
conduct sync — Trigger a one-shot sync cycle

Usage:
  conduct sync

Description:
  Runs a single agent synchronization cycle immediately using the AppImage.
  This will update agent files based on the current conductor.json configuration.

Options:
  --help, -h    Show this help message

Example:
  conduct sync
EOF
}

usage_logs() {
  cat <<EOF
conduct logs — Show con-pilot service logs

Usage:
  conduct logs [-n LINES] [-f | --follow]

Description:
  Prints the last N lines of the con-pilot service log (default: 10).
  Use -f or --follow to stream live output until interrupted (Ctrl+C).

Options:
  -n LINES      Number of lines to show (default: 10)
  -f, --follow  Follow the log in real-time
  --help, -h    Show this help message

Environment:
  CONDUCTOR_HOME    Base directory for conductor (default: ~/.conductor)

Log location:
  \$CONDUCTOR_HOME/con-pilot.log

Examples:
  conduct logs
  conduct logs -n 50
  conduct logs -f
EOF
}

usage_agents() {
  cat <<EOF
conduct agents — List all agents

Usage:
  conduct agents [options]

Description:
  Lists all configured agents (system and project scoped) from the
  con-pilot service, showing their status and file locations.

Options:
  -p, --project PROJECT   Filter agents by project name
  -j, --json              Output raw JSON response
  --help, -h              Show this help message

Output:
  ✓ = agent file exists    ✗ = agent file missing
  [sidekick] = designated sidekick agent

Examples:
  conduct agents                     # List all agents
  conduct agents -p my-project       # List agents for specific project
  conduct agents -j                  # Output as JSON
  conduct agents -p my-project -j    # JSON for specific project
EOF
}

usage_register() {
  cat <<EOF
conduct register — Register a new project

Usage:
  conduct register <name> <directory>

Description:
  Registers a new project with the con-pilot service. The project will
  be added to the project registry and project-scoped agents will be
  created for it.

Arguments:
  name        Unique name for the project
  directory   Absolute path to the project directory

Options:
  --help, -h    Show this help message

Example:
  conduct register my-app /home/user/projects/my-app
EOF
}

usage_retire() {
  cat <<EOF
conduct retire — Retire a project

Usage:
  conduct retire <name>

Description:
  Retires a project from the con-pilot service. Project-scoped agents
  will be moved to the retired/ directory.

Arguments:
  name    Name of the project to retire

Options:
  --help, -h    Show this help message

Example:
  conduct retire my-old-project
EOF
}

usage_verify() {
  cat <<EOF
conduct verify — Verify values with the con-pilot service

Usage:
  conduct verify <item> <value>

Supported items:
  key        Verify the provided install key against the server

Options:
  --help, -h    Show this help message

Examples:
  conduct verify key abc-123
EOF
}

usage_end_points() {
  cat <<EOF
conduct end-points — API endpoint discovery and checks

Usage:
  conduct end-points <subcommand> [args]

Subcommands:
  list                      List endpoint names, methods, paths, args, and body
  ping <endpoint-name>      Ping one endpoint by name and print HTTP status
  show-me                   Call temporary dev diagnostics endpoint (/show-me)

Options:
  --help, -h    Show this help message

Examples:
  conduct end-points list
  conduct end-points ping health
  conduct end-points show-me
EOF
}

# ── Helpers ───────────────────────────────────────────────────────────────────

require_key() {
  if [[ -z "${ADMIN_KEY:-}" ]]; then
    echo "Error: --key is required for admin commands." >&2
    echo "Usage: conduct admin <command> [args] --key <KEY>" >&2
    exit 1
  fi
}

api_get() {
  local endpoint="$1" response
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if response="$(curl -sf --connect-timeout 2 --max-time 5 "$url" 2>/dev/null)"; then
      printf '%s' "$response"
      return 0
    fi
  done
  return 1
}

api_post() {
  local endpoint="$1" body="$2"
  local url
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if curl -sf -X POST "$url" \
      -H "Content-Type: application/json" \
      -d "$body"; then
      return 0
    fi
  done
  return 1
}

endpoint_spec() {
  case "$1" in
    health) echo "GET ${API_PREFIX}/health" ;;
    version) echo "GET ${API_PREFIX}/version" ;;
    login) echo "POST ${API_PREFIX}/login" ;;
    agents) echo "GET ${API_PREFIX}/agents" ;;
    setup-env) echo "GET ${API_PREFIX}/setup-env" ;;
    validate) echo "POST ${API_PREFIX}/validate" ;;
    sync) echo "POST ${API_PREFIX}/sync" ;;
    cron) echo "POST ${API_PREFIX}/cron" ;;
    register) echo "POST ${API_PREFIX}/register" ;;
    retire-project) echo "POST ${API_PREFIX}/retire-project" ;;
    replace) echo "POST ${API_PREFIX}/replace" ;;
    reset) echo "POST ${API_PREFIX}/reset" ;;
    verify-key) echo "POST ${API_PREFIX}/verify-key" ;;
    create-user) echo "POST ${API_PREFIX}/create-user" ;;
    show-me) echo "GET ${API_PREFIX}/show-me" ;;
    config) echo "POST ${API_PREFIX}/config" ;;
    config-version) echo "GET ${API_PREFIX}/config/{version}" ;;
    config-diff) echo "POST ${API_PREFIX}/config/diff" ;;
    config-activate) echo "POST ${API_PREFIX}/config/{version}/activate" ;;
    snapshot) echo "GET ${API_PREFIX}/snapshot" ;;
    snapshot-changes) echo "GET ${API_PREFIX}/snapshot/changes" ;;
    snapshot-check-and-create) echo "POST ${API_PREFIX}/snapshot/check-and-create" ;;
    snapshot-watcher) echo "GET ${API_PREFIX}/snapshot/watcher" ;;
    snapshot-watcher-start) echo "POST ${API_PREFIX}/snapshot/watcher/start" ;;
    snapshot-watcher-stop) echo "POST ${API_PREFIX}/snapshot/watcher/stop" ;;
    *) return 1 ;;
  esac
}

cmd_end_points() {
  if [[ $# -eq 0 ]]; then
    usage_end_points
    exit 0
  fi

  case "$1" in
    -h|--help|help)
      usage_end_points
      exit 0
      ;;
  esac

  local subcmd="$1"
  shift

  case "$subcmd" in
    list)
      cat <<EOF
    health                    | GET  ${API_PREFIX}/health                 | args: none                                   | body: none
    version                   | GET  ${API_PREFIX}/version                | args: none                                   | body: none
    login                     | POST ${API_PREFIX}/login                  | args: none                                   | body: {"username":"<user>","password":"<pass>"}
    agents                    | GET  ${API_PREFIX}/agents                 | args: ?project=<name>                        | body: none
    setup-env                 | GET  ${API_PREFIX}/setup-env              | args: none                                   | body: none
    validate                  | POST ${API_PREFIX}/validate               | args: none                                   | body: {"project":"<name>"}
    sync                      | POST ${API_PREFIX}/sync                   | args: none                                   | body: none
    cron                      | POST ${API_PREFIX}/cron                   | args: none                                   | body: none
    register                  | POST ${API_PREFIX}/register               | args: none                                   | body: {"name":"<name>","directory":"<abs-path>"}
    retire-project            | POST ${API_PREFIX}/retire-project         | args: none                                   | body: {"name":"<name>"}
    replace                   | POST ${API_PREFIX}/replace                | args: none                                   | body: {"file":"<path>","role":"<role>","key":"<key>","project":"<optional>"}
    reset                     | POST ${API_PREFIX}/reset                  | args: none                                   | body: {"role":"<role>","key":"<key>","project":"<optional>"}
    verify-key                | POST ${API_PREFIX}/verify-key             | args: none                                   | body: {"key":"<key>"}
    create-user               | POST ${API_PREFIX}/create-user            | args: header X-Install-Key:<key>             | body: {"username":"<user>","password":"<pass>","active":true}
    show-me                   | GET  ${API_PREFIX}/show-me                | args: env CON_PILOT_DEV_SHOW_ME=1            | body: none
    config                    | POST ${API_PREFIX}/config                 | args: none                                   | body: {"config":{...}}
    config-version            | GET  ${API_PREFIX}/config/{version}       | args: version=<id>                           | body: none
    config-diff               | POST ${API_PREFIX}/config/diff            | args: none                                   | body: {"left_version":"<id>","right_version":"<id>"}
    config-activate           | POST ${API_PREFIX}/config/{version}/activate | args: version=<id>                        | body: none
    snapshot                  | GET  ${API_PREFIX}/snapshot               | args: none                                   | body: none
    snapshot-changes          | GET  ${API_PREFIX}/snapshot/changes       | args: none                                   | body: none
    snapshot-check-and-create | POST ${API_PREFIX}/snapshot/check-and-create | args: none                                | body: none
    snapshot-watcher          | GET  ${API_PREFIX}/snapshot/watcher       | args: none                                   | body: none
    snapshot-watcher-start    | POST ${API_PREFIX}/snapshot/watcher/start | args: none                                   | body: none
    snapshot-watcher-stop     | POST ${API_PREFIX}/snapshot/watcher/stop  | args: none                                   | body: none
EOF
      ;;
    ping)
      if [[ $# -lt 1 ]]; then
        echo "Usage: conduct end-points ping <endpoint-name>" >&2
        exit 1
      fi
      local spec
      if ! spec="$(endpoint_spec "$1")"; then
        echo "Unknown endpoint name: $1" >&2
        echo "Tip: run 'conduct end-points list'" >&2
        exit 1
      fi
      local path="${spec#* }"
      if [[ "$path" == *"{"* ]]; then
        echo "Endpoint '$1' requires path arguments and cannot be pinged by name only." >&2
        exit 1
      fi
      local code
      code="$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 2 --max-time 5 "${BASE_URL}${path}" || true)"
      if [[ "$code" == "000" ]]; then
        echo "Ping failed: no response from ${BASE_URL}${path}" >&2
        exit 1
      fi
      echo "Endpoint '$1' reachable at ${path} (HTTP ${code})."
      ;;
    show-me)
      local output body code
      for url in "${API_URL}/show-me" "${BASE_URL}/show-me" "${BASE_URL}/v1/show-me"; do
        if output="$(curl -sS --connect-timeout 2 --max-time 10 "$url" -w $'\n%{http_code}' 2>/dev/null)"; then
          code="${output##*$'\n'}"
          body="${output%$'\n'*}"
          [[ "$code" != "404" ]] && break
        fi
      done

      if [[ -z "${code:-}" ]]; then
        echo "show-me failed: could not reach ${API_URL}/show-me" >&2
        exit 1
      fi

      if [[ "$code" != "200" ]]; then
        if [[ "$code" == "404" ]]; then
          echo "show-me unavailable: set CON_PILOT_DEV_SHOW_ME=1 on the running service" >&2
        else
          echo "show-me failed: HTTP ${code}" >&2
        fi
        if [[ -n "$body" ]]; then
          echo "$body" >&2
        fi
        exit 1
      fi

      if command -v jq >/dev/null 2>&1; then
        echo "$body" | jq .
      else
        echo "$body"
      fi
      ;;
    *)
      echo "Unknown end-points command: $subcmd" >&2
      usage_end_points >&2
      exit 1
      ;;
  esac
}

# ── Service commands ──────────────────────────────────────────────────────────

cmd_start() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_start; exit 0 ;;
    esac
  done

  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local APPIMAGE="$CONDUCTOR_HOME/con-pilot.AppImage"

  if pgrep -f 'con-pilot serve' >/dev/null 2>&1; then
    echo "con-pilot is already running."
    return 0
  fi

  if [[ ! -x "$APPIMAGE" ]]; then
    echo "Error: AppImage not found at $APPIMAGE" >&2
    exit 1
  fi

  local LOG="$CONDUCTOR_HOME/con-pilot.log"
  mkdir -p "$(dirname "$LOG")"
  CON_PILOT_DEV_SHOW_ME=1 setsid "$APPIMAGE" serve "$@" >> "$LOG" 2>&1 &
  local PID=$!
  echo "con-pilot started (PID $PID), logging to $LOG"

  for i in $(seq 1 15); do
    if api_get "/health" >/dev/null 2>&1; then
      echo "Health check passed."
      return 0
    fi
    sleep 1
  done
  echo "Warning: health check did not pass within 15s."
}

cmd_stop() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_stop; exit 0 ;;
    esac
  done
  pkill -f 'con-pilot serve' && echo "Stopped." || echo "Not running."
}

cmd_status() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_status; exit 0 ;;
    esac
  done
  local health version_resp
  health=$(api_get "/health") || true
  version_resp=$(api_get "/version") || true
  if [[ -z "$health" ]]; then
    echo "con-pilot is NOT running (no response from ${BASE_URL})."
    exit 1
  fi
  local status_val version_val
  status_val=$(printf '%s' "$health" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
  version_val=$(printf '%s' "$version_resp" | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
  # Fall back to VERSION file if the endpoint is absent (older Flatpak build)
  if [[ -z "$version_val" || "$version_val" == "$version_resp" ]]; then
    version_val="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null \
      || cat "${CONDUCTOR_HOME:-$HOME/.conductor}/VERSION" 2>/dev/null \
      || echo 'unknown')"
  fi
  echo "Status:  ${status_val:-unknown}"
  echo "Version: ${version_val:-unknown}"
  echo "URL:     ${BASE_URL}"
}

cmd_sync() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_sync; exit 0 ;;
    esac
  done
  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local APPIMAGE="$CONDUCTOR_HOME/con-pilot.AppImage"
  "$APPIMAGE" sync >> "$CONDUCTOR_HOME/con-pilot.log" 2>&1
}

cmd_logs() {
  local follow=false lines=10
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_logs; exit 0 ;;
      -f|--follow) follow=true; shift ;;
      -n) lines="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; usage_logs >&2; exit 1 ;;
    esac
  done
  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local LOG="$CONDUCTOR_HOME/con-pilot.log"
  if [[ ! -f "$LOG" ]]; then
    mkdir -p "$(dirname "$LOG")"
    touch "$LOG"
    echo "(Log file created — waiting for service output…)" >&2
  fi
  if [[ "$follow" == true ]]; then
    tail -n "$lines" -f "$LOG"
  else
    tail -n "$lines" "$LOG"
  fi
}

cmd_agents() {
  local project="" json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -p|--project) project="$2"; shift 2 ;;
      -j|--json) json="1"; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local response
  if [[ -n "$project" ]]; then
    response=$(api_get "/agents?project=$project") || true
  else
    response=$(api_get "/agents") || true
  fi
  if [[ -z "$response" ]]; then
    echo "Error: Could not reach con-pilot service at $BASE_URL" >&2
    exit 1
  fi

  if [[ -n "$json" ]]; then
    echo "$response"
  else
    # Human-readable output using jq
    echo "$response" | jq -r '
      "System Agents:",
      "------------------------------------------------------------",
      (.system_agents[] | "  \(if .file_exists then "✓" else "✗" end) \(.role): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n      → \(.file_path)" else "" end)"),
      "",
      "Project Agents:",
      "------------------------------------------------------------",
      ((.project_agents | group_by(.project))[] |
        "\n  [\(.[0].project)]",
        (.[] | "    \(if .file_exists then "✓" else "✗" end) \(.role)\(if .instance then " #\(.instance)" else "" end): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n        → \(.file_path)" else "" end)")
      )
    '
  fi
}

# ── Project commands ──────────────────────────────────────────────────────────

cmd_register() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_register; exit 0 ;;
    esac
  done
  if [[ $# -lt 2 ]]; then
    echo "Usage: conduct register <name> <directory>" >&2
    exit 1
  fi
  api_post "/register" "{\"name\": \"$1\", \"directory\": \"$2\"}"
}

cmd_retire() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_retire; exit 0 ;;
    esac
  done
  if [[ $# -lt 1 ]]; then
    echo "Usage: conduct retire <name>" >&2
    exit 1
  fi
  api_post "/retire-project" "{\"name\": \"$1\"}"
}

cmd_verify() {
  # Handle help flags
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_verify; exit 0 ;;
    esac
  done

  if [[ $# -lt 2 ]]; then
    echo "Usage: conduct verify <item> <value>" >&2
    exit 1
  fi

  local item="$1"
  local value="$2"

  case "$item" in
    key)
      local result body code endpoint
      endpoint="${API_PREFIX}/verify-key"
      if ! result="$(curl -sS --connect-timeout 2 --max-time 5 -X POST "${BASE_URL}${endpoint}" \
        -H "Content-Type: application/json" \
        -d "{\"key\": \"$value\"}" \
        -w $'\n%{http_code}')"; then
        echo "Verify failed: could not reach ${BASE_URL}${endpoint}" >&2
        exit 1
      fi

      code="${result##*$'\n'}"
      body="${result%$'\n'*}"

      # Backward-compatibility for older deployments exposing this endpoint elsewhere.
      if [[ "$code" == "404" ]]; then
        for endpoint in "/verify-key" "/v1/verify-key"; do
          if ! result="$(curl -sS --connect-timeout 2 --max-time 5 -X POST "${BASE_URL}${endpoint}" \
            -H "Content-Type: application/json" \
            -d "{\"key\": \"$value\"}" \
            -w $'\n%{http_code}')"; then
            continue
          fi
          code="${result##*$'\n'}"
          body="${result%$'\n'*}"
          [[ "$code" != "404" ]] && break
        done
      fi

      case "$code" in
        200)
          echo "Verified: key"
          ;;
        401)
          echo "Invalid key"
          exit 1
          ;;
        503)
          echo "Verify failed: install key is not available on server"
          exit 1
          ;;
        404)
          echo "Verify failed: endpoint not available on server (deploy a build that includes /verify-key)"
          exit 1
          ;;
        *)
          echo "Verify failed: HTTP ${code}"
          if [[ -n "$body" ]]; then
            echo "$body"
          fi
          exit 1
          ;;
      esac
      ;;
    *)
      echo "Unknown verify item: $item" >&2
      echo "Supported verify items: key" >&2
      exit 1
      ;;
  esac
}

# ── Admin commands ────────────────────────────────────────────────────────────

cmd_admin() {
  if [[ $# -eq 0 ]]; then
    usage_admin
    exit 0
  fi

  # Handle --help as first argument
  case "$1" in
    -h|--help|help)
      usage_admin
      exit 0
      ;;
  esac

  local subcmd="$1"; shift

  # Parse --key from remaining args
  ADMIN_KEY=""
  local positional=()
  local show_help=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --key)
        if [[ $# -lt 2 ]]; then
          echo "Error: --key requires a value." >&2
          exit 1
        fi
        ADMIN_KEY="$2"; shift 2 ;;
      --key=*)
        ADMIN_KEY="${1#--key=}"; shift ;;
      -h|--help)
        show_help="1"; shift ;;
      *)
        positional+=("$1"); shift ;;
    esac
  done

  # Show help if requested (before requiring key)
  if [[ -n "$show_help" ]]; then
    usage_admin
    exit 0
  fi

  require_key

  case "$subcmd" in
    replace)
      if [[ ${#positional[@]} -lt 2 ]]; then
        echo "Usage: conduct admin replace <file> <role> [project] --key KEY" >&2
        exit 1
      fi
      local file="${positional[0]}" role="${positional[1]}" project="${positional[2]:-}"
      local body="{\"file\": \"$file\", \"role\": \"$role\", \"key\": \"$ADMIN_KEY\""
      [[ -n "$project" ]] && body+=", \"project\": \"$project\""
      body+="}"
      api_post "/replace" "$body"
      ;;
    reset)
      if [[ ${#positional[@]} -lt 1 ]]; then
        echo "Usage: conduct admin reset <role> [project] --key KEY" >&2
        exit 1
      fi
      local role="${positional[0]}" project="${positional[1]:-}"
      local body="{\"role\": \"$role\", \"key\": \"$ADMIN_KEY\""
      [[ -n "$project" ]] && body+=", \"project\": \"$project\""
      body+="}"
      api_post "/reset" "$body"
      ;;
    help|--help|-h)
      usage_admin ;;
    *)
      echo "Unknown admin command: $subcmd" >&2
      usage_admin >&2
      exit 1
      ;;
  esac
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  start)     shift; cmd_start "$@" ;;
  stop)      shift; cmd_stop "$@" ;;
  status)    shift; cmd_status "$@" ;;
  sync)      shift; cmd_sync "$@" ;;
  logs|log)  shift; cmd_logs "$@" ;;
  agents)    shift; cmd_agents "$@" ;;
  register)  shift; cmd_register "$@" ;;
  retire)    shift; cmd_retire "$@" ;;
  end-points) shift; cmd_end_points "$@" ;;
  verify)    shift; cmd_verify "$@" ;;
  admin)     shift; cmd_admin "$@" ;;
  version|--version|-v) v="$(get_version)"; echo "Conductor v${v}  (con-pilot v${v})" ;;
  help|--help|-h) usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
