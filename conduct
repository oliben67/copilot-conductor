_cmd_agents_config_show() {
  local json="" name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -j|--json) json="1"; shift ;;
      -*) echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents config show [name] [-j]" >&2
          exit 1
        fi
        ;;
    esac
  done

  local api_out http_status response
  if [[ -n "$name" ]]; then
    api_out=$(api_get_status "/agents/config/${name}") || true
    http_status="$(echo "$api_out" | head -1)"
    response="$(echo "$api_out" | tail -n +2)"
    if [[ "$http_status" == "404" ]]; then
