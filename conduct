cmd_end_points() {
  if [[ $# -eq 0 ]]; then
    usage_end_points
    exit 0
  fi

  case "$1" in
    -h|--help|help)
      usage_end_points
      exit 0
      ;;
  esac

  local subcmd="$1"
  shift

  case "$subcmd" in
    list)
      cat <<EOF
    health                    | GET  ${API_PREFIX}/health                 | args: none                                   | body: none
    version                   | GET  ${API_PREFIX}/version                | args: none                                   | body: none
    login                     | POST ${API_PREFIX}/login                  | args: none                                   | body: {"username":"<user>","password":"<pass>"}
    agents                    | GET  ${API_PREFIX}/agents                 | args: ?project=<name>                        | body: none
    agent-detail              | GET  ${API_PREFIX}/agents/{name}          | args: name=<role-or-display-name>            | body: none
    agent-config              | GET  ${API_PREFIX}/agents/config          | args: none                                   | body: none
    agent-config-detail       | GET  ${API_PREFIX}/agents/config/{name}   | args: name=<role-or-display-name>            | body: none
    agent-config-modify       | PATCH ${API_PREFIX}/agents/config/{name}  | args: name=<role-or-display-name>, header X-Admin-Key:<key> | body: partial config fields
    setup-env                 | GET  ${API_PREFIX}/setup-env              | args: none                                   | body: none
    validate                  | POST ${API_PREFIX}/validate               | args: none                                   | body: {"project":"<name>"}
    sync                      | POST ${API_PREFIX}/sync                   | args: none                                   | body: none
    cron                      | POST ${API_PREFIX}/cron                   | args: none                                   | body: none
    cron-jobs                 | GET  ${API_PREFIX}/cron/jobs              | args: none                                   | body: none
    cron-job-detail           | GET  ${API_PREFIX}/cron/jobs/{name}       | args: name=<task-name>                       | body: none
    cron-job-create           | POST ${API_PREFIX}/cron/jobs              | args: header X-Admin-Key:<key>               | body: {"name":"...","agent":"...","description":"...","instructions":"...","cron":"..."}
    cron-job-modify           | PATCH ${API_PREFIX}/cron/jobs/{name}      | args: name=<task-name>, header X-Admin-Key:<key> | body: partial task fields
    cron-job-delete           | DELETE ${API_PREFIX}/cron/jobs/{name}     | args: name=<task-name>, header X-Admin-Key:<key> | body: none
