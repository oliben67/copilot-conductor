    fi
  else
    response=$(api_get "/agents/config") || true
    if [[ -z "$response" ]]; then
      echo "Error: Could not reach con-pilot service at $BASE_URL" >&2
      exit 1
    fi
  fi

  if [[ -n "$json" ]]; then
