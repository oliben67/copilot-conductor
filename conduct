    dispatcher-drain)   _tasks_dispatcher_drain "$@" ;;
    *)
      echo "Unknown tasks subcommand: $subcmd" >&2
      usage_tasks >&2
      exit 1
      ;;
  esac
}

_tasks_dispatcher_status() {
  local json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_tasks; exit 0 ;;
      -j|--json) json="1"; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done
  local api_out http_status response
  api_out="$(api_get_status "/tasks/dispatcher/status")" || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"
  case "$http_status" in
    200) : ;;
    503) echo "Error: dispatcher is not running" >&2; exit 1 ;;
    000) echo "Error: Service unreachable at $BASE_URL" >&2; exit 1 ;;
    *) echo "Error: request failed (HTTP ${http_status})" >&2
       [[ -n "$response" ]] && echo "$response" >&2; exit 1 ;;
  esac
  if [[ -n "$json" ]] || ! command -v jq >/dev/null 2>&1; then
    print_json_pretty "$response"
  else
    echo "$response" | jq -r '
      "Pending Dispatcher",
      "------------------------------------------------------------",
      "  Running:        \(if .running then "yes" else "no" end)",
      "  Processed:      \(.processed)",
      "  Failed:         \(.failed)",
      "  Skipped:        \(.skipped)",
      "  Pending offset: \(.pending_offset) / \(.pending_size) bytes",
      (if .last_run then "  Last run:       \(.last_run)" else empty end),
      (if .last_error then "  Last error:     \(.last_error)" else empty end)
    '
  fi
}

_tasks_dispatcher_drain() {
  local key="" json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_tasks; exit 0 ;;
      -j|--json) json="1"; shift ;;
      --key)
        if [[ $# -lt 2 ]]; then echo "Error: --key requires a value" >&2; exit 1; fi
        key="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done
  if [[ -z "$key" ]]; then echo "Error: --key is required" >&2; exit 1; fi
  local api_out http_status response
  api_out="$(api_post_status_with_key "/tasks/dispatcher/drain" "{}" "$key")" || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"
  case "$http_status" in
    200|201|202) : ;;
    503) echo "Error: dispatcher is not running" >&2; exit 1 ;;
    401|403)
      echo "Error: request failed (HTTP ${http_status})" >&2
      [[ -n "$response" ]] && echo "$response" >&2
      exit 1 ;;
    000) echo "Error: Service unreachable at $BASE_URL" >&2; exit 1 ;;
    *) echo "Error: request failed (HTTP ${http_status})" >&2
       [[ -n "$response" ]] && echo "$response" >&2; exit 1 ;;
  esac
  if [[ -n "$json" ]] || ! command -v jq >/dev/null 2>&1; then
    print_json_pretty "$response"
  else
    echo "$response" | jq -r '"Drain: processed=\(.processed) failed=\(.failed) skipped=\(.skipped)"'
  fi
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  start)     shift; cmd_start "$@" ;;
  stop)      shift; cmd_stop "$@" ;;
  status)    shift; cmd_status "$@" ;;
  sync)      shift; cmd_sync "$@" ;;
  logs|log)  shift; cmd_logs "$@" ;;
  cron)      shift; cmd_cron "$@" ;;
  tasks)     shift; cmd_tasks "$@" ;;
  agents)    shift; cmd_agents "$@" ;;
  register)  shift; cmd_register "$@" ;;
  retire)    shift; cmd_retire "$@" ;;
  end-points) shift; cmd_end_points "$@" ;;
  verify)    shift; cmd_verify "$@" ;;
  admin)     shift; cmd_admin "$@" ;;
  version|--version|-v)
    v="$(get_version)"
    echo "Conductor v${v}  (con-pilot v${v})"
    if [[ "${v}" == *-dev || "${v}" == *.dev* || "${v}" == *+dev* ]]; then
      echo "WARNING: this is a DEV BUILD (${v}); not for production use."
    fi
    ;;
  help|--help|-h) usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac
