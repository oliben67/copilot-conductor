      "  Scheduled:    \(if .scheduled then "yes" else "no" end)",
      "  Registered:   \(if .registered then "yes" else "no" end)",
      (if .next_run_time then "  Next run:     \(.next_run_time)" else empty end),
      (if .create_on_ping then "  Create-on-ping: yes" else empty end),
      (if (.permissions // []) | length > 0 then "  Permissions:  \(.permissions | join(", "))" else empty end),
