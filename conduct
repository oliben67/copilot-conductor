api_delete_status_with_key() {
  local endpoint="$1" key="$2" out http_status resp
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    out="$(curl -s --connect-timeout 2 --max-time 10 -X DELETE "$url" \
