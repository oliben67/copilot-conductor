_cmd_agents_config_modify() {
  local name="" json="" key=""
  local set_name="" set_model="" set_description="" set_instructions=""
  local set_active="" set_sidekick="" set_augmenting=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -j|--json) json="1"; shift ;;
      --key)
        if [[ $# -lt 2 ]]; then
          echo "Error: --key requires a value" >&2
          exit 1
        fi
        key="$2"; shift 2 ;;
      --name)
        if [[ $# -lt 2 ]]; then
          echo "Error: --name requires a value" >&2
          exit 1
        fi
        set_name="$2"; shift 2 ;;
      --active)
        if [[ $# -lt 2 ]]; then
          echo "Error: --active requires true|false" >&2
          exit 1
        fi
        set_active="$2"; shift 2 ;;
      --sidekick)
        if [[ $# -lt 2 ]]; then
          echo "Error: --sidekick requires true|false" >&2
          exit 1
        fi
        set_sidekick="$2"; shift 2 ;;
      --augmenting)
        if [[ $# -lt 2 ]]; then
          echo "Error: --augmenting requires true|false" >&2
          exit 1
        fi
        set_augmenting="$2"; shift 2 ;;
      --model)
        if [[ $# -lt 2 ]]; then
          echo "Error: --model requires a value" >&2
          exit 1
        fi
        set_model="$2"; shift 2 ;;
      --description)
        if [[ $# -lt 2 ]]; then
          echo "Error: --description requires a value" >&2
          exit 1
        fi
        set_description="$2"; shift 2 ;;
      --instructions)
        if [[ $# -lt 2 ]]; then
          echo "Error: --instructions requires a value" >&2
          exit 1
        fi
        set_instructions="$2"; shift 2 ;;
      -*)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents config modify <name> [fields] --key KEY [-j]" >&2
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "Usage: conduct agents config modify <name> [fields] --key KEY [-j]" >&2
    exit 1
  fi
  if [[ -z "$key" ]]; then
    echo "Error: --key is required" >&2
    exit 1
  fi

  local payload='{}'
  local change_count=0
  if [[ -n "$set_name" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_name" '. + {name:$v}')"
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_model" ]]; then
    if [[ "$set_model" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {model:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_model" '. + {model:$v}')"
    fi
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_description" ]]; then
    if [[ "$set_description" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {description:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_description" '. + {description:$v}')"
    fi
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_instructions" ]]; then
    if [[ "$set_instructions" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {instructions:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_instructions" '. + {instructions:$v}')"
    fi
    change_count=$((change_count + 1))
  fi

  case "$set_active" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_active" '. + {active:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --active must be true or false" >&2
      exit 1
      ;;
  esac

  case "$set_sidekick" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_sidekick" '. + {sidekick:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --sidekick must be true or false" >&2
      exit 1
      ;;
  esac

  case "$set_augmenting" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_augmenting" '. + {augmenting:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --augmenting must be true or false" >&2
      exit 1
      ;;
  esac

  if [[ "$change_count" -eq 0 ]]; then
    echo "Error: no config fields provided to modify" >&2
    exit 1
  fi

  local api_out http_status response
  api_out="$(api_patch_status_with_key "/agents/config/${name}" "$payload" "$key")" || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"

  case "$http_status" in
    200)
      if [[ -n "$json" ]]; then
        print_json_pretty "$response"
      else
        echo "$response" | jq -r '
          "Updated Agent Config: \(.name) (\(.role))",
          "------------------------------------------------------------",
          "  Scope:       \(.scope)",
          "  Active:      \(if .active then "yes" else "no" end)",
          "  Sidekick:    \(if .sidekick then "yes" else "no" end)",
          "  Augmenting:  \(if .augmenting then "yes" else "no" end)",
          "  Model:       \(.model // "[default]")",
          (if .description then "  Description: \(.description)" else empty end),
          (if .instructions then "  Instructions: \(.instructions)" else empty end)
        '
      fi
      ;;
    400|401|403|404|422)
      echo "Error: request failed (HTTP ${http_status})" >&2
      if [[ -n "$response" ]]; then
        echo "$response" >&2
      fi
      exit 1
      ;;
    000)
      echo "Error: Service unreachable at $BASE_URL" >&2
      exit 1
      ;;
    *)
      echo "Error: request failed (HTTP ${http_status})" >&2
      if [[ -n "$response" ]]; then
        echo "$response" >&2
      fi
      exit 1
      ;;
  esac
}

