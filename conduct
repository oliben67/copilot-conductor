# ── Helpers ───────────────────────────────────────────────────────────────────

print_json_pretty() {
  local payload="$1"
  if command -v jq >/dev/null 2>&1 && printf '%s' "$payload" | jq -e . >/dev/null 2>&1; then
    printf '%s' "$payload" | jq --indent 2 '.'
  else
    printf '%s\n' "$payload"
  fi
}

require_key() {
  if [[ -z "${ADMIN_KEY:-}" ]]; then
    echo "Error: --key is required for admin commands." >&2
    echo "Usage: conduct admin <command> [args] --key <KEY>" >&2
    exit 1
  fi
}

api_get() {
  local endpoint="$1" response
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if response="$(curl -sf --connect-timeout 2 --max-time 5 "$url" 2>/dev/null)"; then
      printf '%s' "$response"
      return 0
    fi
  done
  return 1
}

# Like api_get but outputs "<http_status> <body>" so callers can distinguish
# 404 (not found) from connection failures (status 000).
api_get_status() {
  local endpoint="$1" out http_status body
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    out="$(curl -s --connect-timeout 2 --max-time 5 -w '\n%{http_code}' "$url" 2>/dev/null)" || true
    http_status="${out##*$'\n'}"
    body="${out%$'\n'*}"
    if [[ "$http_status" =~ ^[2-9][0-9][0-9]$ ]]; then
      printf '%s\n%s' "$http_status" "$body"
      return 0
    elif [[ "$http_status" =~ ^[0-9]+$ && "$http_status" != "000" ]]; then
      # Got an HTTP response (e.g. 404) — not a connection failure
      printf '%s\n%s' "$http_status" "$body"
      return 1
    fi
    # connection failure (status 000) — try next URL variant
  done
  printf '000\n'
  return 1
}

api_post() {
  local endpoint="$1" body="$2" response
  local url
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    if response="$(curl -sf -X POST "$url" \
      -H "Content-Type: application/json" \
      -d "$body")"; then
      print_json_pretty "$response"
      return 0
    fi
  done
  return 1
}

api_patch_status_with_key() {
  local endpoint="$1" body="$2" key="$3" out http_status resp
  for url in "${API_URL}${endpoint}" "${BASE_URL}${endpoint}" "${BASE_URL}/v1${endpoint}"; do
    out="$(curl -s --connect-timeout 2 --max-time 10 -X PATCH "$url" \
      -H "Content-Type: application/json" \
      -H "X-Admin-Key: ${key}" \
      -d "$body" \
      -w '\n%{http_code}' 2>/dev/null)" || true
    http_status="${out##*$'\n'}"
    resp="${out%$'\n'*}"
    if [[ "$http_status" =~ ^[2-9][0-9][0-9]$ ]]; then
      printf '%s\n%s' "$http_status" "$resp"
      return 0
    elif [[ "$http_status" =~ ^[0-9]+$ && "$http_status" != "000" ]]; then
      printf '%s\n%s' "$http_status" "$resp"
      return 1
    fi
  done
  printf '000\n'
  return 1
}

endpoint_spec() {
  case "$1" in
    health) echo "GET ${API_PREFIX}/health" ;;
    version) echo "GET ${API_PREFIX}/version" ;;
    login) echo "POST ${API_PREFIX}/login" ;;
    agents) echo "GET ${API_PREFIX}/agents" ;;
    agent-detail) echo "GET ${API_PREFIX}/agents/{name}" ;;
    agent-config) echo "GET ${API_PREFIX}/agents/config" ;;
    agent-config-detail) echo "GET ${API_PREFIX}/agents/config/{name}" ;;
    agent-config-modify) echo "PATCH ${API_PREFIX}/agents/config/{name}" ;;
    setup-env) echo "GET ${API_PREFIX}/setup-env" ;;
    validate) echo "POST ${API_PREFIX}/validate" ;;
    sync) echo "POST ${API_PREFIX}/sync" ;;
    cron) echo "POST ${API_PREFIX}/cron" ;;
    register) echo "POST ${API_PREFIX}/register" ;;
    retire-project) echo "POST ${API_PREFIX}/retire-project" ;;
    replace) echo "POST ${API_PREFIX}/replace" ;;
    reset) echo "POST ${API_PREFIX}/reset" ;;
    verify-key) echo "POST ${API_PREFIX}/verify-key" ;;
    create-user) echo "POST ${API_PREFIX}/create-user" ;;
    show-me) echo "GET ${API_PREFIX}/show-me" ;;
    config) echo "POST ${API_PREFIX}/config" ;;
    config-version) echo "GET ${API_PREFIX}/config/{version}" ;;
    config-diff) echo "POST ${API_PREFIX}/config/diff" ;;
    config-activate) echo "POST ${API_PREFIX}/config/{version}/activate" ;;
    snapshot) echo "GET ${API_PREFIX}/snapshot" ;;
    snapshot-changes) echo "GET ${API_PREFIX}/snapshot/changes" ;;
    snapshot-check-and-create) echo "POST ${API_PREFIX}/snapshot/check-and-create" ;;
    snapshot-watcher) echo "GET ${API_PREFIX}/snapshot/watcher" ;;
    snapshot-watcher-start) echo "POST ${API_PREFIX}/snapshot/watcher/start" ;;
    snapshot-watcher-stop) echo "POST ${API_PREFIX}/snapshot/watcher/stop" ;;
    *) return 1 ;;
  esac
}

cmd_end_points() {
  if [[ $# -eq 0 ]]; then
    usage_end_points
    exit 0
  fi

  case "$1" in
    -h|--help|help)
      usage_end_points
      exit 0
      ;;
  esac

  local subcmd="$1"
  shift

  case "$subcmd" in
    list)
      cat <<EOF
    health                    | GET  ${API_PREFIX}/health                 | args: none                                   | body: none
    version                   | GET  ${API_PREFIX}/version                | args: none                                   | body: none
    login                     | POST ${API_PREFIX}/login                  | args: none                                   | body: {"username":"<user>","password":"<pass>"}
    agents                    | GET  ${API_PREFIX}/agents                 | args: ?project=<name>                        | body: none
    agent-detail              | GET  ${API_PREFIX}/agents/{name}          | args: name=<role-or-display-name>            | body: none
    agent-config              | GET  ${API_PREFIX}/agents/config          | args: none                                   | body: none
    agent-config-detail       | GET  ${API_PREFIX}/agents/config/{name}   | args: name=<role-or-display-name>            | body: none
    agent-config-modify       | PATCH ${API_PREFIX}/agents/config/{name}  | args: name=<role-or-display-name>, header X-Admin-Key:<key> | body: partial config fields
    setup-env                 | GET  ${API_PREFIX}/setup-env              | args: none                                   | body: none
    validate                  | POST ${API_PREFIX}/validate               | args: none                                   | body: {"project":"<name>"}
    sync                      | POST ${API_PREFIX}/sync                   | args: none                                   | body: none
    cron                      | POST ${API_PREFIX}/cron                   | args: none                                   | body: none
    register                  | POST ${API_PREFIX}/register               | args: none                                   | body: {"name":"<name>","directory":"<abs-path>"}
    retire-project            | POST ${API_PREFIX}/retire-project         | args: none                                   | body: {"name":"<name>"}
    replace                   | POST ${API_PREFIX}/replace                | args: none                                   | body: {"file":"<path>","role":"<role>","key":"<key>","project":"<optional>"}
    reset                     | POST ${API_PREFIX}/reset                  | args: none                                   | body: {"role":"<role>","key":"<key>","project":"<optional>"}
    verify-key                | POST ${API_PREFIX}/verify-key             | args: none                                   | body: {"key":"<key>"}
    create-user               | POST ${API_PREFIX}/create-user            | args: header X-Install-Key:<key>             | body: {"username":"<user>","password":"<pass>","active":true}
    show-me                   | GET  ${API_PREFIX}/show-me                | args: env CON_PILOT_DEV_SHOW_ME=1            | body: none
    config                    | POST ${API_PREFIX}/config                 | args: none                                   | body: {"config":{...}}
    config-version            | GET  ${API_PREFIX}/config/{version}       | args: version=<id>                           | body: none
    config-diff               | POST ${API_PREFIX}/config/diff            | args: none                                   | body: {"left_version":"<id>","right_version":"<id>"}
    config-activate           | POST ${API_PREFIX}/config/{version}/activate | args: version=<id>                        | body: none
    snapshot                  | GET  ${API_PREFIX}/snapshot               | args: none                                   | body: none
    snapshot-changes          | GET  ${API_PREFIX}/snapshot/changes       | args: none                                   | body: none
    snapshot-check-and-create | POST ${API_PREFIX}/snapshot/check-and-create | args: none                                | body: none
    snapshot-watcher          | GET  ${API_PREFIX}/snapshot/watcher       | args: none                                   | body: none
    snapshot-watcher-start    | POST ${API_PREFIX}/snapshot/watcher/start | args: none                                   | body: none
    snapshot-watcher-stop     | POST ${API_PREFIX}/snapshot/watcher/stop  | args: none                                   | body: none
EOF
      ;;
    ping)
      if [[ $# -lt 1 ]]; then
        echo "Usage: conduct end-points ping <endpoint-name>" >&2
        exit 1
      fi
      local spec
      if ! spec="$(endpoint_spec "$1")"; then
        echo "Unknown endpoint name: $1" >&2
        echo "Tip: run 'conduct end-points list'" >&2
        exit 1
      fi
      local path="${spec#* }"
      if [[ "$path" == *"{"* ]]; then
        echo "Endpoint '$1' requires path arguments and cannot be pinged by name only." >&2
        exit 1
      fi
      local code
      code="$(curl -s -o /dev/null -w '%{http_code}' --connect-timeout 2 --max-time 5 "${BASE_URL}${path}" || true)"
      if [[ "$code" == "000" ]]; then
        echo "Ping failed: no response from ${BASE_URL}${path}" >&2
        exit 1
      fi
      echo "Endpoint '$1' reachable at ${path} (HTTP ${code})."
      ;;
    show-me)
      local output body code
      for url in "${API_URL}/show-me" "${BASE_URL}/show-me" "${BASE_URL}/v1/show-me"; do
        if output="$(curl -sS --connect-timeout 2 --max-time 10 "$url" -w $'\n%{http_code}' 2>/dev/null)"; then
          code="${output##*$'\n'}"
          body="${output%$'\n'*}"
          [[ "$code" != "404" ]] && break
        fi
      done

      if [[ -z "${code:-}" ]]; then
        echo "show-me failed: could not reach ${API_URL}/show-me" >&2
        exit 1
      fi

      if [[ "$code" != "200" ]]; then
        if [[ "$code" == "404" ]]; then
          echo "show-me unavailable: set CON_PILOT_DEV_SHOW_ME=1 on the running service" >&2
        else
          echo "show-me failed: HTTP ${code}" >&2
        fi
        if [[ -n "$body" ]]; then
          echo "$body" >&2
        fi
        exit 1
      fi

      if command -v jq >/dev/null 2>&1; then
        echo "$body" | jq --indent 2 .
      else
        echo "$body"
      fi
      ;;
    *)
      echo "Unknown end-points command: $subcmd" >&2
      usage_end_points >&2
      exit 1
      ;;
  esac
}

# ── Service commands ──────────────────────────────────────────────────────────

cmd_start() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_start; exit 0 ;;
    esac
  done

  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local APPIMAGE="$CONDUCTOR_HOME/con-pilot.AppImage"

  if pgrep -f 'con-pilot serve' >/dev/null 2>&1; then
    echo "con-pilot is already running."
    return 0
  fi

  if [[ ! -x "$APPIMAGE" ]]; then
    echo "Error: AppImage not found at $APPIMAGE" >&2
    exit 1
  fi

  local LOG="$CONDUCTOR_HOME/con-pilot.log"
  mkdir -p "$(dirname "$LOG")"
  CON_PILOT_DEV_SHOW_ME=1 setsid "$APPIMAGE" serve "$@" >> "$LOG" 2>&1 &
  local PID=$!
  echo "con-pilot started (PID $PID), logging to $LOG"

  for i in $(seq 1 15); do
    if api_get "/health" >/dev/null 2>&1; then
      echo "Health check passed."
      return 0
    fi
    sleep 1
  done
  echo "Warning: health check did not pass within 15s."
}

cmd_stop() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_stop; exit 0 ;;
    esac
  done
  pkill -f 'con-pilot serve' && echo "Stopped." || echo "Not running."
}

cmd_status() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_status; exit 0 ;;
    esac
  done
  local health version_resp
  health=$(api_get "/health") || true
  version_resp=$(api_get "/version") || true
  if [[ -z "$health" ]]; then
    echo "con-pilot is NOT running (no response from ${BASE_URL})."
    exit 1
  fi
  local status_val version_val
  status_val=$(printf '%s' "$health" | sed 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
  version_val=$(printf '%s' "$version_resp" | sed 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/')
  # Fall back to VERSION file if the endpoint is absent (older Flatpak build)
  if [[ -z "$version_val" || "$version_val" == "$version_resp" ]]; then
    version_val="$(cat "$SCRIPT_DIR/VERSION" 2>/dev/null \
      || cat "${CONDUCTOR_HOME:-$HOME/.conductor}/VERSION" 2>/dev/null \
      || echo 'unknown')"
  fi
  echo "Status:  ${status_val:-unknown}"
  echo "Version: ${version_val:-unknown}"
  echo "URL:     ${BASE_URL}"
}

cmd_sync() {
  # Handle --help
  for arg in "$@"; do
    case "$arg" in
      -h|--help) usage_sync; exit 0 ;;
    esac
  done
  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local APPIMAGE="$CONDUCTOR_HOME/con-pilot.AppImage"
  "$APPIMAGE" sync >> "$CONDUCTOR_HOME/con-pilot.log" 2>&1
}

cmd_logs() {
  local follow=false lines=10
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_logs; exit 0 ;;
      -f|--follow) follow=true; shift ;;
      -n) lines="$2"; shift 2 ;;
      *) echo "Unknown option: $1" >&2; usage_logs >&2; exit 1 ;;
    esac
  done
  local CONDUCTOR_HOME="${CONDUCTOR_HOME:-$HOME/.conductor}"
  local LOG="$CONDUCTOR_HOME/con-pilot.log"
  if [[ ! -f "$LOG" ]]; then
    mkdir -p "$(dirname "$LOG")"
    touch "$LOG"
    echo "(Log file created — waiting for service output…)" >&2
  fi
  if [[ "$follow" == true ]]; then
    tail -n "$lines" -f "$LOG"
  else
    tail -n "$lines" "$LOG"
  fi
}

cmd_agents() {
  if [[ $# -eq 0 ]]; then
    echo "Error: 'conduct agents' requires a subcommand." >&2
    echo "Use: conduct agents show --all" >&2
    exit 1
  fi

  local subcmd=""
  case "$1" in
    show|config) subcmd="$1"; shift ;;
    -h|--help) usage_agents; exit 0 ;;
    *)
      echo "Error: Unknown agents subcommand '$1'" >&2
      echo "Use: conduct agents show --all" >&2
      exit 1
      ;;
  esac

  if [[ "$subcmd" == "show" ]]; then
    _cmd_agents_show "$@"
  else
    _cmd_agents_config "$@"
  fi
}

_cmd_agents_list() {
  local project="" json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -p|--project) project="$2"; shift 2 ;;
      -j|--json) json="1"; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local response
  if [[ -n "$project" ]]; then
    response=$(api_get "/agents?project=$project") || true
  else
    response=$(api_get "/agents") || true
  fi
  if [[ -z "$response" ]]; then
    echo "Error: Could not reach con-pilot service at $BASE_URL" >&2
    exit 1
  fi

  if [[ -n "$json" ]]; then
    print_json_pretty "$response"
  else
    echo "$response" | jq -r '
      "System Agents:",
      "------------------------------------------------------------",
      (.system_agents[] | "  \(if .file_exists then "✓" else "✗" end) \(.role): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n      → \(.file_path)" else "" end)"),
      "",
      "Project Agents:",
      "------------------------------------------------------------",
      ((.project_agents | group_by(.project))[] |
        "\n  [\(.[0].project)]",
        (.[] | "    \(if .file_exists then "✓" else "✗" end) \(.role)\(if .instance then " #\(.instance)" else "" end): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n        → \(.file_path)" else "" end)")
      )
    '
  fi
}

_cmd_agents_show() {
  local json="" name="" all=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -f) json="1"; shift ;;
      --all) all="1"; shift ;;
      -*) echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
          exit 1
        fi
        ;;
    esac
  done

  if [[ -n "$all" && -n "$name" ]]; then
    echo "Error: --all cannot be combined with an agent name" >&2
    echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
    exit 1
  fi

  if [[ -n "$all" ]]; then
    _cmd_agents_list ${json:+-j}
    return
  fi

  if [[ -z "$name" ]]; then
    echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
    exit 1
  fi

  local api_out http_status response
  api_out=$(api_get_status "/agents/${name}") || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"
  if [[ "$http_status" == "404" ]]; then
    echo "Error: Agent '${name}' not found" >&2
    exit 1
  elif [[ -z "$response" || "$http_status" == "000" || ! "$http_status" =~ ^2 ]]; then
    echo "Error: Service unreachable at $BASE_URL" >&2
    exit 1
  fi

  if [[ -n "$json" ]]; then
    print_json_pretty "$response"
    return
  fi

  echo "$response" | jq -r '
    "Agent: \(.name) (\(.role))",
    "------------------------------------------------------------",
    "  Scope:       \(.scope)",
    "  Active:      \(if .active then "yes" else "no" end)",
    "  File:        \(if .file_exists then .file_path else "[missing]" end)",
    (if .model then "  Model:       \(.model)" else empty end),
    (if .description then "  Description: \(.description)" else empty end),
    (if .sidekick then "  Sidekick:    yes" else empty end),
    (if .augmenting then "  Augmenting:  yes" else empty end),
    "",
    "  Permissions (\(.permissions | length)):",
    (.permissions[] | "    - \(.)"),
    "",
    "  Assigned Tasks (\(.tasks | length)):",
    if (.tasks | length) == 0 then "    (none)"
    else
      (.tasks[] |
        "    \(.name)\(if .cron then " [cron: \(.cron)]" else " [manual]" end)",
        "      \(.description)"
      )
    end,
    (if .cron then "\n  Own Cron Schedule: \(.cron.expression)" else empty end),
    (if .instances then "\n  Instances: min=\(.instances.min) max=\(.instances.max // .instances.min)" else empty end),
    (if .instructions then "\n  Instructions:\n\(.instructions | split("\n") | map("    " + .) | join("\n"))" else empty end)
  '
}

_cmd_agents_config() {
  local subcmd="show"
  if [[ $# -gt 0 ]]; then
    case "$1" in
      show|modify) subcmd="$1"; shift ;;
      -h|--help) usage_agents; exit 0 ;;
    esac
  fi

  case "$subcmd" in
    show) _cmd_agents_config_show "$@" ;;
    modify) _cmd_agents_config_modify "$@" ;;
  esac
}

_cmd_agents_config_show() {
  local json="" name=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -j|--json) json="1"; shift ;;
      -*) echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents config show [name] [-j]" >&2
          exit 1
        fi
        ;;
    esac
  done

  local api_out http_status response
  if [[ -n "$name" ]]; then
    api_out=$(api_get_status "/agents/config/${name}") || true
    http_status="$(echo "$api_out" | head -1)"
    response="$(echo "$api_out" | tail -n +2)"
    if [[ "$http_status" == "404" ]]; then
      echo "Error: Agent '${name}' not found" >&2
      exit 1
    elif [[ -z "$response" || "$http_status" == "000" || ! "$http_status" =~ ^2 ]]; then
      echo "Error: Service unreachable at $BASE_URL" >&2
      exit 1
    fi
  else
    response=$(api_get "/agents/config") || true
    if [[ -z "$response" ]]; then
      echo "Error: Could not reach con-pilot service at $BASE_URL" >&2
      exit 1
    fi
  fi

  if [[ -n "$json" ]]; then
    print_json_pretty "$response"
    return
  fi

  if [[ -n "$name" ]]; then
    echo "$response" | jq --indent 2 .
  else
    echo "$response" | jq -r '
      "Agent Configurations:",
      "------------------------------------------------------------",
      (to_entries[] |
        "\(.key):",
        "  name: \(.value.name // .key)",
        "  scope: \(.value.scope)",
        "  active: \(if .value.active then "yes" else "no" end)",
        "  model: \(.value.model // "[default]")",
        "  running: \(if .value.running then "yes" else "no" end)",
        ""
      )
    '
  fi
}

_cmd_agents_config_modify() {
  local name="" json="" key=""
  local set_name="" set_model="" set_description="" set_instructions=""
  local set_active="" set_sidekick="" set_augmenting=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -j|--json) json="1"; shift ;;
      --key)
        if [[ $# -lt 2 ]]; then
          echo "Error: --key requires a value" >&2
          exit 1
        fi
        key="$2"; shift 2 ;;
      --name)
        if [[ $# -lt 2 ]]; then
          echo "Error: --name requires a value" >&2
          exit 1
        fi
        set_name="$2"; shift 2 ;;
      --active)
        if [[ $# -lt 2 ]]; then
          echo "Error: --active requires true|false" >&2
          exit 1
        fi
        set_active="$2"; shift 2 ;;
      --sidekick)
        if [[ $# -lt 2 ]]; then
          echo "Error: --sidekick requires true|false" >&2
          exit 1
        fi
        set_sidekick="$2"; shift 2 ;;
      --augmenting)
        if [[ $# -lt 2 ]]; then
          echo "Error: --augmenting requires true|false" >&2
          exit 1
        fi
        set_augmenting="$2"; shift 2 ;;
      --model)
        if [[ $# -lt 2 ]]; then
          echo "Error: --model requires a value" >&2
          exit 1
        fi
        set_model="$2"; shift 2 ;;
      --description)
        if [[ $# -lt 2 ]]; then
          echo "Error: --description requires a value" >&2
          exit 1
        fi
        set_description="$2"; shift 2 ;;
      --instructions)
        if [[ $# -lt 2 ]]; then
          echo "Error: --instructions requires a value" >&2
          exit 1
        fi
        set_instructions="$2"; shift 2 ;;
      -*)
        echo "Unknown option: $1" >&2
        exit 1
        ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents config modify <name> [fields] --key KEY [-j]" >&2
          exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$name" ]]; then
    echo "Usage: conduct agents config modify <name> [fields] --key KEY [-j]" >&2
    exit 1
  fi
  if [[ -z "$key" ]]; then
    echo "Error: --key is required" >&2
    exit 1
  fi

  local payload='{}'
  local change_count=0
  if [[ -n "$set_name" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_name" '. + {name:$v}')"
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_model" ]]; then
    if [[ "$set_model" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {model:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_model" '. + {model:$v}')"
    fi
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_description" ]]; then
    if [[ "$set_description" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {description:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_description" '. + {description:$v}')"
    fi
    change_count=$((change_count + 1))
  fi
  if [[ -n "$set_instructions" ]]; then
    if [[ "$set_instructions" == "" ]]; then
      payload="$(echo "$payload" | jq '. + {instructions:null}')"
    else
      payload="$(echo "$payload" | jq --arg v "$set_instructions" '. + {instructions:$v}')"
    fi
    change_count=$((change_count + 1))
  fi

  case "$set_active" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_active" '. + {active:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --active must be true or false" >&2
      exit 1
      ;;
  esac

  case "$set_sidekick" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_sidekick" '. + {sidekick:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --sidekick must be true or false" >&2
      exit 1
      ;;
  esac

  case "$set_augmenting" in
    true|false)
      payload="$(echo "$payload" | jq --argjson v "$set_augmenting" '. + {augmenting:$v}')"
      change_count=$((change_count + 1))
      ;;
    "") ;;
    *)
      echo "Error: --augmenting must be true or false" >&2
      exit 1
      ;;
  esac

  if [[ "$change_count" -eq 0 ]]; then
    echo "Error: no config fields provided to modify" >&2
    exit 1
  fi

  local api_out http_status response
  api_out="$(api_patch_status_with_key "/agents/config/${name}" "$payload" "$key")" || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"

  case "$http_status" in
    200)
      if [[ -n "$json" ]]; then
        print_json_pretty "$response"
      else
        echo "$response" | jq -r '
          "Updated Agent Config: \(.name) (\(.role))",
          "------------------------------------------------------------",
          "  Scope:       \(.scope)",
          "  Active:      \(if .active then "yes" else "no" end)",
          "  Sidekick:    \(if .sidekick then "yes" else "no" end)",
          "  Augmenting:  \(if .augmenting then "yes" else "no" end)",
          "  Model:       \(.model // "[default]")",
          (if .description then "  Description: \(.description)" else empty end),
          (if .instructions then "  Instructions: \(.instructions)" else empty end)
        '
      fi
      ;;
    400|401|403|404|422)
      echo "Error: request failed (HTTP ${http_status})" >&2
      if [[ -n "$response" ]]; then
        echo "$response" >&2
      fi
      exit 1
      ;;
    000)
      echo "Error: Service unreachable at $BASE_URL" >&2
      exit 1
      ;;
    *)
      echo "Error: request failed (HTTP ${http_status})" >&2
      if [[ -n "$response" ]]; then
        echo "$response" >&2
      fi
      exit 1
      ;;
  esac
}

