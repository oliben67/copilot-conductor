_cron_collect_fields() {
  # Reads cron add/modify options into a JSON payload via jq.
  # Usage: _cron_collect_fields <out-var> <include-required:true|false> -- "$@"
  local __outvar="$1"; shift
  local __require="$1"; shift
  [[ "$1" == "--" ]] && shift
  local set_name="" set_agent="" set_description="" set_instructions=""
  local set_cron="" set_create_on_ping="" set_permissions=""
  local name_pos=""
  local json="" key=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_cron; exit 0 ;;
      -j|--json) json="1"; shift ;;
      --key)
        if [[ $# -lt 2 ]]; then echo "Error: --key requires a value" >&2; exit 1; fi
        key="$2"; shift 2 ;;
      --name)
        if [[ $# -lt 2 ]]; then echo "Error: --name requires a value" >&2; exit 1; fi
        set_name="$2"; shift 2 ;;
      --agent)
        if [[ $# -lt 2 ]]; then echo "Error: --agent requires a value" >&2; exit 1; fi
        set_agent="$2"; shift 2 ;;
      --description)
        if [[ $# -lt 2 ]]; then echo "Error: --description requires a value" >&2; exit 1; fi
        set_description="$2"; shift 2 ;;
      --instructions)
        if [[ $# -lt 2 ]]; then echo "Error: --instructions requires a value" >&2; exit 1; fi
        set_instructions="$2"; shift 2 ;;
      --cron)
        if [[ $# -lt 2 ]]; then echo "Error: --cron requires a value" >&2; exit 1; fi
        set_cron="$2"; shift 2 ;;
      --create-on-ping)
        if [[ $# -lt 2 ]]; then echo "Error: --create-on-ping requires true|false" >&2; exit 1; fi
        set_create_on_ping="$2"; shift 2 ;;
      --permissions)
        if [[ $# -lt 2 ]]; then echo "Error: --permissions requires a value" >&2; exit 1; fi
        set_permissions="$2"; shift 2 ;;
      -*)
        echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$name_pos" ]]; then
          name_pos="$1"; shift
        else
          echo "Unexpected argument: $1" >&2; exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$key" ]]; then
    echo "Error: --key is required" >&2
    exit 1
  fi
  if ! command -v jq >/dev/null 2>&1; then
    echo "Error: 'jq' is required for cron add/modify" >&2
    exit 1
  fi

  local payload='{}'
  if [[ -n "$set_name" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_name" '. + {name:$v}')"
  fi
  if [[ -n "$set_agent" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_agent" '. + {agent:$v}')"
  fi
  if [[ -n "$set_description" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_description" '. + {description:$v}')"
  fi
  if [[ -n "$set_instructions" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_instructions" '. + {instructions:$v}')"
  fi
  if [[ -n "$set_cron" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_cron" '. + {cron:$v}')"
  fi
  if [[ -n "$set_create_on_ping" ]]; then
    case "$set_create_on_ping" in
      true|false)
        payload="$(echo "$payload" | jq --argjson v "$set_create_on_ping" '. + {create_on_ping:$v}')" ;;
      *) echo "Error: --create-on-ping must be true or false" >&2; exit 1 ;;
    esac
  fi
  if [[ -n "$set_permissions" ]]; then
    payload="$(echo "$payload" | jq --arg v "$set_permissions" '. + {permissions: ($v | split(",") | map(gsub("^ +| +$";"")) | map(select(length>0)))}')"
  fi

  # For modify, positional name is the target; ensure we pass it out too.
  printf -v "$__outvar" '%s' "$payload"
  # shellcheck disable=SC2034
  CRON_FIELDS_NAME_POS="$name_pos"
  # shellcheck disable=SC2034
  CRON_FIELDS_JSON="$json"
  # shellcheck disable=SC2034
  CRON_FIELDS_KEY="$key"

  if [[ "$__require" == "true" ]]; then
    for req in name agent description instructions; do
      if ! echo "$payload" | jq -e --arg k "$req" '.[$k] // empty' >/dev/null; then
        echo "Error: --${req} is required" >&2
        exit 1
      fi
    done
  fi
}

