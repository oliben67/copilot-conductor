_cmd_agents_list() {
  local project="" json=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -p|--project) project="$2"; shift 2 ;;
      -j|--json) json="1"; shift ;;
      *) echo "Unknown option: $1" >&2; exit 1 ;;
    esac
  done

  local response
  if [[ -n "$project" ]]; then
    response=$(api_get "/agents?project=$project") || true
  else
    response=$(api_get "/agents") || true
  fi
  if [[ -z "$response" ]]; then
    echo "Error: Could not reach con-pilot service at $BASE_URL" >&2
    exit 1
  fi

  if [[ -n "$json" ]]; then
    print_json_pretty "$response"
  else
    echo "$response" | jq -r '
      "System Agents:",
      "------------------------------------------------------------",
      (.system_agents[] | "  \(if .file_exists then "✓" else "✗" end) \(.role): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n      → \(.file_path)" else "" end)"),
      "",
      "Project Agents:",
      "------------------------------------------------------------",
      ((.project_agents | group_by(.project))[] |
        "\n  [\(.[0].project)]",
        (.[] | "    \(if .file_exists then "✓" else "✗" end) \(.role)\(if .instance then " #\(.instance)" else "" end): \(.name) (\(if .active then "active" else "inactive" end))\(if .sidekick then " [sidekick]" else "" end)\(if .file_exists then "\n        → \(.file_path)" else "" end)")
      )
    '
  fi
}

_cmd_agents_show() {
  local json="" name="" all=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -h|--help) usage_agents; exit 0 ;;
      -f) json="1"; shift ;;
      --all) all="1"; shift ;;
      -*) echo "Unknown option: $1" >&2; exit 1 ;;
      *)
        if [[ -z "$name" ]]; then
          name="$1"
          shift
        else
          echo "Unexpected argument: $1" >&2
          echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
          exit 1
        fi
        ;;
    esac
  done

  if [[ -n "$all" && -n "$name" ]]; then
    echo "Error: --all cannot be combined with an agent name" >&2
    echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
    exit 1
  fi

  if [[ -n "$all" ]]; then
    _cmd_agents_list ${json:+-j}
    return
  fi

  if [[ -z "$name" ]]; then
    echo "Usage: conduct agents show --all [-f] | conduct agents show <name> [-f]" >&2
    exit 1
  fi

  local api_out http_status response
  api_out=$(api_get_status "/agents/${name}") || true
  http_status="$(echo "$api_out" | head -1)"
  response="$(echo "$api_out" | tail -n +2)"
  if [[ "$http_status" == "404" ]]; then
    echo "Error: Agent '${name}' not found" >&2
    exit 1
  elif [[ -z "$response" || "$http_status" == "000" || ! "$http_status" =~ ^2 ]]; then
    echo "Error: Service unreachable at $BASE_URL" >&2
    exit 1
  fi

  if [[ -n "$json" ]]; then
    print_json_pretty "$response"
    return
  fi

  echo "$response" | jq -r '
    "Agent: \(.name) (\(.role))",
    "------------------------------------------------------------",
    "  Scope:       \(.scope)",
    "  Active:      \(if .active then "yes" else "no" end)",
    "  File:        \(if .file_exists then .file_path else "[missing]" end)",
    (if .model then "  Model:       \(.model)" else empty end),
    (if .description then "  Description: \(.description)" else empty end),
    (if .sidekick then "  Sidekick:    yes" else empty end),
    (if .augmenting then "  Augmenting:  yes" else empty end),
    "",
    "  Permissions (\(.permissions | length)):",
    (.permissions[] | "    - \(.)"),
    "",
    "  Assigned Tasks (\(.tasks | length)):",
    if (.tasks | length) == 0 then "    (none)"
    else
      (.tasks[] |
        "    \(.name)\(if .cron then " [cron: \(.cron)]" else " [manual]" end)",
        "      \(.description)"
      )
    end,
    (if .cron then "\n  Own Cron Schedule: \(.cron.expression)" else empty end),
    (if .instances then "\n  Instances: min=\(.instances.min) max=\(.instances.max // .instances.min)" else empty end),
    (if .instructions then "\n  Instructions:\n\(.instructions | split("\n") | map("    " + .) | join("\n"))" else empty end)
  '
}

