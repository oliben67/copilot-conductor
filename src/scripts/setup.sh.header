#!/usr/bin/env bash
# ── Conductor Self-Extracting Installer ───────────────────────────────────────
# Version: __VERSION__
# Built:   __BUILD_DATE__
# Usage:   ./setup.sh install | update
set -euo pipefail

VERSION="__VERSION__"
CON_PILOT_VERSION="__CON_PILOT_VERSION__"
APP_ID="io.conductor.ConPilot"
BASHRC="$HOME/.bashrc"
DEFAULT_HOME="$HOME/.conductor"

# ── Usage ─────────────────────────────────────────────────────────────────────

usage() {
  cat <<EOF
Conductor Setup v${VERSION}  (con-pilot v${CON_PILOT_VERSION})

Usage:
  ./$0 install   [CONDUCTOR_HOME] [GITHUB_TOKEN]   Extract and install Conductor
  ./$0 update                                       Update to this version (v${VERSION})
  ./$0 version                                      Show bundled version
  ./$0 help                                         Show this help message

Arguments:
  CONDUCTOR_HOME   Target directory (uses \$CONDUCTOR_HOME if set)
  GITHUB_TOKEN     GitHub token (optional if COPILOT_GITHUB_TOKEN, GH_TOKEN, or GITHUB_TOKEN is set)

Environment:
  COPILOT_GITHUB_TOKEN, GH_TOKEN, GITHUB_TOKEN — Checked in order for GitHub access
EOF
}

# ── Shared functions ─────────────────────────────────────────────────────────

# __FUNCTIONS__

# ── GitHub token ──────────────────────────────────────────────────────────────

resolve_github_token() {
  # Check for existing token env vars in priority order
  local token="${COPILOT_GITHUB_TOKEN:-${GH_TOKEN:-${GITHUB_TOKEN:-}}}"
  if [[ -n "$token" ]]; then
    echo "$token"
    return 0
  fi
  return 1
}

require_github_token() {
  local provided_token="${1:-}"
  local resolved_token

  if resolved_token=$(resolve_github_token); then
    echo "Using GitHub token from environment."
    export COPILOT_GITHUB_TOKEN="$resolved_token"
    return 0
  fi

  if [[ -n "$provided_token" ]]; then
    echo "Using provided GitHub token."
    export COPILOT_GITHUB_TOKEN="$provided_token"
    return 0
  fi

  echo "Error: GitHub token is required for installation." >&2
  echo "" >&2
  echo "Provide a token via:" >&2
  echo "  1. Command line:  ./setup.sh install CONDUCTOR_HOME GITHUB_TOKEN" >&2
  echo "  2. Environment:   export COPILOT_GITHUB_TOKEN=<token>" >&2
  echo "                    export GH_TOKEN=<token>" >&2
  echo "                    export GITHUB_TOKEN=<token>" >&2
  echo "" >&2
  echo "Generate a token at: https://github.com/settings/tokens" >&2
  exit 1
}

require_flatpak() {
  if ! command -v flatpak >/dev/null 2>&1; then
    echo "Error: Flatpak is not installed." >&2
    echo "Install it first:  https://flatpak.org/setup/" >&2
    exit 1
  fi
}

# ── Flatpak ───────────────────────────────────────────────────────────────────

archive_line() {
  # Line number where the tar.gz payload begins
  awk '/^__ARCHIVE__$/{print NR + 1; exit 0}' "$0"
}

extract_to() {
  local dest="$1"
  mkdir -p "$dest"
  tail -n +"$(archive_line)" "$0" | tar xzf - -C "$dest" --strip-components=1
}

persist_var() {
  local var_name="$1" var_value="$2"
  if grep -q "^export ${var_name}=" "$BASHRC" 2>/dev/null; then
    sed -i "s|^export ${var_name}=.*|export ${var_name}=\"${var_value}\"|" "$BASHRC"
  else
    printf 'export %s="%s"\n' "$var_name" "$var_value" >> "$BASHRC"
  fi
}

ensure_flatpak_runtime() {
  if ! flatpak --user info org.freedesktop.Platform//24.08 &>/dev/null; then
    echo "Installing Flatpak runtime (org.freedesktop.Platform 24.08)…"
    flatpak --user install -y flathub org.freedesktop.Platform//24.08
  fi
}

install_flatpak() {
  local conductor_home="$1" force="${2:-false}"
  local bundle="${conductor_home}/python/con-pilot/dist/io.conductor.ConPilot.flatpak"

  if [[ ! -f "$bundle" ]]; then
    echo "Error: Flatpak bundle not found at ${bundle}" >&2
    exit 1
  fi

  ensure_flatpak_runtime

  if flatpak --user info "$APP_ID" &>/dev/null; then
    if [[ "$force" == true ]]; then
      echo "Removing existing Flatpak…"
      flatpak --user uninstall -y "$APP_ID" 2>/dev/null || true
      rm -rf "$HOME/.var/app/${APP_ID}"
    else
      echo "con-pilot Flatpak is already installed. Use 'update' to upgrade."
      return 0
    fi
  fi

  echo "Installing Flatpak from ${bundle}…"
  flatpak --user install --noninteractive "$bundle"

  local host="${CON_PILOT_HOST:-localhost}"
  local port="${CON_PILOT_PORT:-8000}"
  local token="${COPILOT_GITHUB_TOKEN:-}"
  flatpak --user override \
    --env=CONDUCTOR_HOME="$conductor_home" \
    --env=CON_PILOT_HOST="$host" \
    --env=CON_PILOT_PORT="$port" \
    --env=COPILOT_GITHUB_TOKEN="$token" \
    "$APP_ID"
  echo "Forwarded env vars into the Flatpak sandbox."
}

# ── Commands ──────────────────────────────────────────────────────────────────

cmd_install() {
  require_flatpak
  local conductor_home="${1:-}"
  local github_token="${2:-}"

  # If no argument provided, check if CONDUCTOR_HOME is already set
  if [[ -z "$conductor_home" ]]; then
    if [[ -n "${CONDUCTOR_HOME:-}" ]]; then
      echo "CONDUCTOR_HOME is already set to: ${CONDUCTOR_HOME}"
      read -r -p "Install to this location? [Y/n] " answer
      case "${answer:-Y}" in
        [Yy]*|"") conductor_home="$CONDUCTOR_HOME" ;;
        *)
          echo "Aborted."
          exit 0
          ;;
      esac
    else
      echo "Error: CONDUCTOR_HOME is required." >&2
      echo "Usage: ./setup.sh install CONDUCTOR_HOME [GITHUB_TOKEN]" >&2
      exit 1
    fi
  fi

  # Require GitHub token (from env or argument)
  require_github_token "$github_token"

  echo "Installing Conductor v${VERSION} to ${conductor_home}…"

  extract_to "$conductor_home"
  echo "Extracted to ${conductor_home}."
  grep -q '# Conductor' "$BASHRC" 2>/dev/null || printf '\n# Conductor\n' >> "$BASHRC"
  persist_var CONDUCTOR_HOME "$conductor_home"
  persist_var CON_PILOT_HOST "${CON_PILOT_HOST:-localhost}"
  persist_var CON_PILOT_PORT "${CON_PILOT_PORT:-8000}"
  persist_var COPILOT_GITHUB_TOKEN "$COPILOT_GITHUB_TOKEN"

  # Install bash completion
  local completion_dir="$HOME/.local/share/bash-completion/completions"
  mkdir -p "$completion_dir"
  if [[ -f "${conductor_home}/conduct.bash-completion" ]]; then
    cp "${conductor_home}/conduct.bash-completion" "$completion_dir/conduct"
    rm -f "${conductor_home}/conduct.bash-completion"
    echo "Bash completion installed to ${completion_dir}/conduct"
  fi
  # Also add to PATH if not already there
  if ! grep -q "PATH=.*${conductor_h[tool.ruff]
line-length = 100
target-version = "py313"

[tool.ruff.lint]
select = ["E", "F", "W", "I", "UP", "B", "SIM"]
ignore = []

[tool.ruff.lint.per-file-ignores]
"src/con_pilot/conductor.py" = ["E501"]  # long lines inside docstrings and Markdown templates

[tool.ruff.format]
quote-style = "double"
indent-style = "space"
docstring-code-format = true
ome}" "$BASHRC" 2>/dev/null; then
    echo "export PATH=\"\$PATH:${conductor_home}\"" >> "$BASHRC"
  fi

  echo "Environment variables persisted in ${BASHRC}."

  install_flatpak "$conductor_home" false
  start_and_healthcheck
  show_key

  # Clean up: leave only conduct, README.md, uninstall.sh
  rm -rf "${conductor_home}/python"
  echo "Cleaned up installation files."

  echo ""
  echo "Conductor v${VERSION} installed successfully."
  echo "Run:  source ${BASHRC}"
}

cmd_update() {
  require_flatpak
  local conductor_home="${CONDUCTOR_HOME:-}"
  if [[ -z "$conductor_home" ]]; then
    echo "Error: CONDUCTOR_HOME is not set. Run 'source ~/.bashrc' or install first." >&2
    exit 1
  fi

  echo "Updating Conductor to v${VERSION}…"

  # Stop server before update
  if pgrep -f 'con-pilot serve' >/dev/null 2>&1; then
    pkill -f 'con-pilot serve' || true
    echo "Stopped running con-pilot serve."
  fi

  extract_to "$conductor_home"
  echo "Extracted v${VERSION} to ${conductor_home}."

  # Update bash completion
  local completion_dir="$HOME/.local/share/bash-completion/completions"
  mkdir -p "$completion_dir"
  if [[ -f "${conductor_home}/conduct.bash-completion" ]]; then
    cp "${conductor_home}/conduct.bash-completion" "$completion_dir/conduct"
    rm -f "${conductor_home}/conduct.bash-completion"
    echo "Bash completion updated."
  fi

  install_flatpak "$conductor_home" true
  start_and_healthcheck
  show_key

  # Clean up: leave only conduct, README.md, uninstall.sh
  rm -rf "${conductor_home}/python"
  echo "Cleaned up installation files."

  echo ""
  echo "Conductor updated to v${VERSION}."
}

# ── Main ──────────────────────────────────────────────────────────────────────

if [[ $# -eq 0 ]]; then
  usage
  exit 0
fi

case "$1" in
  install)   shift; cmd_install "$@" ;;
  update)    cmd_update ;;
  version)   echo "Conductor v${VERSION}  (con-pilot v${CON_PILOT_VERSION})" ;;
  help|--help|-h) usage ;;
  *)
    echo "Unknown command: $1" >&2
    usage >&2
    exit 1
    ;;
esac

exit 0
__ARCHIVE__
