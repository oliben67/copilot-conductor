# ── Helpers ───────────────────────────────────────────────────────────────────

archive_line() {
  # Line number where the tar.gz payload begins
  awk '/^__ARCHIVE__$/{print NR + 1; exit 0}' "$0"
}

extract_to() {
  local dest="$1"
  mkdir -p "$dest"
  tail -n +"$(archive_line)" "$0" | tar xzf - -C "$dest" --strip-components=1
}

persist_var() {
  local var_name="$1" var_value="$2"
  if grep -q "^export ${var_name}=" "$BASHRC" 2>/dev/null; then
    sed -i "s|^export ${var_name}=.*|export ${var_name}=\"${var_value}\"|" "$BASHRC"
  else
    printf 'export %s="%s"\n' "$var_name" "$var_value" >> "$BASHRC"
  fi
}

stop_existing() {
  if pgrep -f 'con-pilot serve' >/dev/null 2>&1; then
    echo "Stopping existing con-pilot process…"
    pkill -f 'con-pilot serve' || true
    sleep 1
  fi
}

start_and_healthcheck() {
  local host="${CON_PILOT_HOST:-localhost}"
  local port="${CON_PILOT_PORT:-8000}"
  local appimage="${CONDUCTOR_HOME}/con-pilot.AppImage"

  stop_existing

  if [[ ! -x "$appimage" ]]; then
    echo "Error: AppImage not found or not executable at ${appimage}" >&2
    exit 1
  fi

  local log="${CONDUCTOR_HOME}/con-pilot.log"
  setsid "$appimage" serve >> "$log" 2>&1 &
  local pid=$!
  local url="http://${host}:${port}/health"
  echo "Waiting for ${url}…"

  for i in $(seq 1 15); do
    if curl -sf "$url" >/dev/null 2>&1; then
      echo "Health check passed — con-pilot is running (PID ${pid}). Logs: ${log}"
      return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
      echo "Error: con-pilot process exited unexpectedly." >&2
      exit 1
    fi
    sleep 1
  done

  echo "Error: con-pilot did not become healthy after 15s." >&2
  kill "$pid" 2>/dev/null || true
  exit 1
}

show_key() {
  local key_file="${CONDUCTOR_HOME}/key"

  local new_key
  new_key="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid)"
  echo "$new_key" > "$key_file"
  chmod 600 "$key_file"

  echo ""
  echo "ADMIN KEY (save this NOW — it will NOT be shown again): $new_key"
  echo ""
  echo "Key stored at ${key_file}"
}
