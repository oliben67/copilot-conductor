# ── Helpers ───────────────────────────────────────────────────────────────────

archive_line() {
  # Line number where the tar.gz payload begins
  awk '/^__ARCHIVE__$/{print NR + 1; exit 0}' "$0"
}

extract_to() {
  local dest="$1"
  mkdir -p "$dest"
  tail -n +"$(archive_line)" "$0" | tar xzf - -C "$dest" --strip-components=1
}

persist_var() {
  local var_name="$1" var_value="$2"
  if grep -q "^export ${var_name}=" "$BASHRC" 2>/dev/null; then
    sed -i "s|^export ${var_name}=.*|export ${var_name}=\"${var_value}\"|" "$BASHRC"
  else
    printf 'export %s="%s"\n' "$var_name" "$var_value" >> "$BASHRC"
  fi
}

stop_existing() {
  if pgrep -f 'con-pilot serve' >/dev/null 2>&1; then
    echo "Stopping existing con-pilot process…"
    pkill -f 'con-pilot serve' || true
    sleep 1
  fi
}

start_and_healthcheck() {
  local host="${CON_PILOT_HOST:-localhost}"
  local port="${CON_PILOT_PORT:-8000}"
  local appimage="${CONDUCTOR_HOME}/con-pilot.AppImage"

  stop_existing

  if [[ ! -x "$appimage" ]]; then
    echo "Error: AppImage not found or not executable at ${appimage}" >&2
    exit 1
  fi

  local log="${CONDUCTOR_HOME}/con-pilot.log"
  CON_PILOT_DEV_SHOW_ME=1 setsid "$appimage" serve >> "$log" 2>&1 &
  local pid=$!
  local api_prefix="/${CON_PILOT_API_BASE:-api}/${CON_PILOT_API_VERSION:-v1}"
  local url="http://${host}:${port}${api_prefix}/health"
  local legacy_url="http://${host}:${port}/health"
  echo "Waiting for ${url}…"

  for i in $(seq 1 15); do
    if curl -sf "$url" >/dev/null 2>&1 || curl -sf "$legacy_url" >/dev/null 2>&1; then
      echo "Health check passed — con-pilot is running (PID ${pid}). Logs: ${log}"
      return 0
    fi
    if ! kill -0 "$pid" 2>/dev/null; then
      echo "Error: con-pilot process exited unexpectedly." >&2
      exit 1
    fi
    sleep 1
  done

  echo "Error: con-pilot did not become healthy after 15s." >&2
  kill "$pid" 2>/dev/null || true
  exit 1
}

show_key() {
  local appimage="${CONDUCTOR_HOME}/con-pilot.AppImage"
  local new_key
  new_key="$(uuidgen 2>/dev/null || cat /proc/sys/kernel/random/uuid)"

  local tmpdir
  tmpdir="$(mktemp -d)"
  cleanup_show_key() {
    rm -rf "${tmpdir:-}"
  }
  trap cleanup_show_key RETURN

  (
    cd "$tmpdir"
    "$appimage" --appimage-extract >/dev/null
  )
  local appdir_src="$tmpdir/squashfs-root"
  if [[ ! -d "$appdir_src" ]]; then
    echo "Error: failed to extract AppImage payload from ${appimage}" >&2
    exit 1
  fi

  printf '%s\n' "$new_key" > "$appdir_src/key"
  chmod 600 "$appdir_src/key"

  local tool_dir="${CONDUCTOR_HOME}/.tools"
  local tool="${tool_dir}/appimagetool-x86_64.AppImage"
  if [[ ! -f "$tool" ]]; then
    mkdir -p "$tool_dir"
    echo "Downloading appimagetool (continuous)…"
    curl -fsSL -o "$tool" \
      "https://github.com/AppImage/AppImageKit/releases/download/continuous/appimagetool-x86_64.AppImage"
    chmod +x "$tool"
  fi

  local rebuilt="$tmpdir/con-pilot-with-key.AppImage"
  ARCH=x86_64 APPIMAGE_EXTRACT_AND_RUN=1 "$tool" "$appdir_src" "$rebuilt" >/dev/null
  chmod +x "$rebuilt"
  mv "$rebuilt" "$appimage"

  # Never leave a host-side key file on disk.
  rm -f "${CONDUCTOR_HOME}/key"

  echo ""
  echo "ADMIN KEY (save this NOW — it will NOT be shown again): $new_key"
  echo ""
}
