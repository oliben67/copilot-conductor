{
  "name": "conduct-lectern",
  "displayName": "Conduct Lectern",
  "description": "Configure and manage the Conductor home directory",
  "version": "0.1.0",
  "publisher": "oliben67",
  "repository": {
    "type": "git",
    "url": "https://github.com/oliben67/copilot-conductor.git",
    "directory": "src/vscode/conduct-lectern"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "icons/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "conductor",
          "title": "Conductor",
          "icon": "icons/icon.svg"
        }
      ]
    },
    "views": {
      "conductor": [
        {
          "id": "conductor.homeView",
          "name": "Home",
          "icon": "icons/icon.svg"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "conductor.homeView",
        "contents": "Conductor home directory is not yet configured.\n[Select Home Directory](command:conductor.selectHome)",
        "when": "!conductor.homeExists"
      }
    ],
    "configuration": {
      "title": "Conductor",
      "properties": {
        "conductor.home": {
          "type": "string",
          "default": "~/.conductor",
          "markdownDescription": "Path to the Conductor home directory. Supports `~` for the user's home directory. Defaults to `~/.conductor`.",
          "scope": "machine-overridable",
          "order": 1
        }
      }
    },
    "commands": [
      {
        "command": "conductor.openHome",
        "title": "Open Conductor Home",
        "category": "Conductor",
        "icon": {
          "light": "icons/light/icon.svg",
          "dark": "icons/dark/icon.svg"
        }
      },
      {
        "command": "conductor.selectHome",
        "title": "Select Conductor Home Directory",
        "category": "Conductor",
        "icon": {
          "light": "icons/light/icon.svg",
          "dark": "icons/dark/icon.svg"
        }
      },
      {
        "command": "conductor.refreshHomeView",
        "title": "Refresh",
        "category": "Conductor",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "conductor.openHome"
        },
        {
          "command": "conductor.selectHome"
        }
      ],
      "view/title": [
        {
          "command": "conductor.openHome",
          "when": "view == conductor.homeView",
          "group": "navigation@1"
        },
        {
          "command": "conductor.selectHome",
          "when": "view == conductor.homeView",
          "group": "navigation@2"
        },
        {
          "command": "conductor.refreshHomeView",
          "when": "view == conductor.homeView",
          "group": "navigation@3"
        }
      ]
    }
  },
  "scripts": {
    "icons:sync": "node ./scripts/sync-icons.mjs",
    "compile": "tsc -p tsconfig.json",
    "compile:check": "tsc -p tsconfig.json --noEmit",
    "watch": "tsc -p tsconfig.json --watch",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:integration": "vscode-test",
    "test": "npm run compile:check && npm run lint && npm run test:unit && npm run test:integration",
    "test:ci": "npm run compile:check && npm run lint && npm run test:unit",
    "build": "rimraf dist && npm run compile",
    "clean": "rimraf dist",
    "version:sync": "node -e \"const fs=require('fs'),p=require('./package.json');p.version=fs.readFileSync('./VERSION','utf8').trim();fs.writeFileSync('./package.json',JSON.stringify(p,null,2)+'\\n');console.log('version set to '+p.version)\"",
    "package": "npm run icons:sync && npm run version:sync && npm run build && vsce package --out $(git rev-parse --show-toplevel)/releases/v$(cat $(git rev-parse --show-toplevel)/src/python/con-pilot/VERSION | tr -d '[:space:]')/",
    "deploy": "code --install-extension $(git rev-parse --show-toplevel)/releases/v$(cat $(git rev-parse --show-toplevel)/src/python/con-pilot/VERSION | tr -d '[:space:]')/conduct-lectern-$(cat VERSION | tr -d '[:space:]').vsix"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.0",
    "@vscode/vsce": "^3.0.0",
    "eslint": "^9.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
