# Python-generated files
__pycache__/
*.py[oc]
build/
*.egg-info

# Virtual environments
.venv/
src/python/**/.venv/

# Build / release artefacts
dist/
wheels/
.task/
.flatpak-builder/
src/python/con-pilot/appimage/AppDir/
src/python/con-pilot/appimage/tools/

# Flatpak repo (built by flatpak-builder)
src/python/con-pilot/flatpak/repo/
src/python/con-pilot/flatpak/build-dir/
src/python/con-pilot/flatpak/deps/

# Secrets
key

# Caches
.pytest_cache/
.ruff_cache/

# IDE
.vscode/

# Sandbox / scratch notebooks
.sandbox/

# Runtime state
.copilot/system/agents/cron/.state/
.copilot/system/agents/cron/pending.log

# Copilot session logs
.copilot/

# VS Code extension — generated and local-only files
src/vscode/conduct-lectern/node_modules/
src/vscode/conduct-lectern/dist/
src/vscode/conduct-lectern/.vscode-test/
src/vscode/conduct-lectern/.task/
src/vscode/conduct-lectern/package-lock.json

.copilot/

# dev only
.dev-artefacts/
*-dev/

# SQLite databases (e.g. from tests or local development).
# These may contain sensitive data and are not needed in version control.
*.sqlite*