# Bash completion for conduct
# Source this file or place in /etc/bash_completion.d/ or ~/.local/share/bash-completion/completions/

_conduct_completions() {
    local cur prev words cword
    _init_completion || return

    local commands="start stop status sync logs agents register retire admin help"
    local admin_commands="replace reset help"

    case "${cword}" in
        1)
            # First argument: main commands
            COMPREPLY=($(compgen -W "${commands}" -- "${cur}"))
            ;;
        *)
            case "${words[1]}" in
                agents)
                    # conduct agents [-p PROJECT] [-j]
                    case "${prev}" in
                        -p|--project)
                            # Complete with project names from the API if available
                            local projects
                            projects=$(curl -sf http://localhost:8000/agents 2>/dev/null | \
                                jq -r '.project_agents[].project // empty' 2>/dev/null | sort -u)
                            COMPREPLY=($(compgen -W "${projects}" -- "${cur}"))
                            ;;
                        *)
                            COMPREPLY=($(compgen -W "-p --project -j --json" -- "${cur}"))
                            ;;
                    esac
                    ;;
                register)
                    # conduct register <name> <directory>
                    case "${cword}" in
                        2)
                            # Project name - no completion
                            ;;
                        3)
                            # Directory - file completion
                            COMPREPLY=($(compgen -d -- "${cur}"))
                            ;;
                    esac
                    ;;
                retire)
                    # conduct retire <name> - complete with registered projects
                    if [[ "${cword}" -eq 2 ]]; then
                        local projects
                        projects=$(curl -sf http://localhost:8000/agents 2>/dev/null | \
                            jq -r '.project_agents[].project // empty' 2>/dev/null | sort -u)
                        COMPREPLY=($(compgen -W "${projects}" -- "${cur}"))
                    fi
                    ;;
                admin)
                    case "${cword}" in
                        2)
                            # Admin subcommand
                            COMPREPLY=($(compgen -W "${admin_commands}" -- "${cur}"))
                            ;;
                        *)
                            case "${words[2]}" in
                                replace)
                                    # conduct admin replace <file> <role> [project] --key KEY
                                    case "${prev}" in
                                        --key)
                                            # Key value - no completion
                                            ;;
                                        replace)
                                            # File completion
                                            COMPREPLY=($(compgen -f -- "${cur}"))
                                            ;;
                                        *)
                                            if [[ "${cur}" == -* ]]; then
                                                COMPREPLY=($(compgen -W "--key" -- "${cur}"))
                                            else
                                                # Role or project - try to get roles from config
                                                local roles="conductor support arbitrator git reviewer developer agile tester"
                                                COMPREPLY=($(compgen -W "${roles} --key" -- "${cur}"))
                                            fi
                                            ;;
                                    esac
                                    ;;
                                reset)
                                    # conduct admin reset <role> [project] --key KEY
                                    case "${prev}" in
                                        --key)
                                            # Key value - no completion
                                            ;;
                                        *)
                                            if [[ "${cur}" == -* ]]; then
                                                COMPREPLY=($(compgen -W "--key" -- "${cur}"))
                                            else
                                                local roles="conductor support arbitrator git reviewer developer agile tester"
                                                COMPREPLY=($(compgen -W "${roles} --key" -- "${cur}"))
                                            fi
                                            ;;
                                    esac
                                    ;;
                            esac
                            ;;
                    esac
                    ;;
                start)
                    # conduct start [--host HOST] [--port PORT]
                    case "${prev}" in
                        --host) ;;
                        --port) ;;
                        *)
                            COMPREPLY=($(compgen -W "--host --port" -- "${cur}"))
                            ;;
                    esac
                    ;;
                *)
                    # No further completion for other commands
                    ;;
            esac
            ;;
    esac
}

complete -F _conduct_completions conduct
